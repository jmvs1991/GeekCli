    <packageSource key="dotnet-dev-vzla/NetCore">
      <package pattern="devVzla.MemoryCache" />
      <package pattern="devVzla.EFExtension" />
      <package pattern="devVzla.Logger" />
      <package pattern="devVzla.Rabbit" />
      <package pattern="devVzla.MongoDriverExtension" />
