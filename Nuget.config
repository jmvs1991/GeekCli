<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Official NuGet package source -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    
    <!-- My custom package source -->
    <add key="dotnet-dev-vzla/BankCore" value="https://dotnet-dev-vzla-411270824898.d.codeartifact.us-east-1.amazonaws.com/nuget/BankCore/v3/index.json" />
    <add key="dotnet-dev-vzla/HandlersCore" value="https://dotnet-dev-vzla-411270824898.d.codeartifact.us-east-1.amazonaws.com/nuget/HandlersCore/v3/index.json" />
