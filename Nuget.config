  </packageSources>

  <packageSourceMapping>
    <packageSource key="dotnet-dev-vzla/BankCore">
      <package pattern="devVzla.BancaAmiga" />
      <package pattern="devVzla.BancoBicentenario" />
      <package pattern="devVzla.BancoVzla" />
